{
	"name": "wtr-lab-retranslate",
	"version": "0.1.0",
	"description": "Adds a Free Batch Retranslate button to the WTR-Lab Batch Re-Translate drawer, letting users batch-retranslate chapters filtered by model using the free daily quota — no tickets, no payment bypass, same-origin fetch only.",
	"author": "MasuRii",
	"license": "MIT",
	"private": true,
	"main": "dist/wtr-lab-retranslate.user.js",
	"engines": {
		"node": ">=20.19.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/MasuRii/wtr-lab-retranslate.git"
	},
	"bugs": {
		"url": "https://github.com/MasuRii/wtr-lab-retranslate/issues"
	},
	"keywords": [
		"wtr-lab",
		"retranslate",
		"batch",
		"free-quota",
		"userscript",
		"webpack"
	],
	"files": [
		"dist/",
		"src/"
	],
	"scripts": {
		"build": "webpack --config webpack.config.cjs --mode=production",
		"build:performance": "webpack --config webpack.config.cjs --config-name performance --mode=production",
		"build:greasyfork": "webpack --config webpack.config.cjs --config-name greasyfork --mode=production",
		"build:devbundle": "webpack --config webpack.config.cjs --config-name dev --mode=development",
		"dev": "webpack serve --config webpack.config.cjs --config-name dev --mode=development",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src test --max-warnings 0",
		"test": "jest",
		"test:watch": "jest --watch",
		"validate:userscript": "node scripts/validate-userscript.cjs",
		"validate": "npm run typecheck && npm run lint && npm run test && npm run build && npm run validate:userscript"
	},
	"devDependencies": {
		"@types/jest": "^29.5.14",
		"@types/node": "^20.19.42",
		"eslint": "^10.4.1",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"ts-jest": "^29.4.11",
		"ts-loader": "^9.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"webpack": "^5.107.2",
		"webpack-cli": "^7.2.1",
		"webpack-dev-server": "^6.0.0",
		"webpack-userscript": "^3.2.3"
	}
}
